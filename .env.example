# GitHub Personal Access Token.
# Optional for many public PRs, recommended to avoid low unauthenticated rate limits.
GITHUB_TOKEN=

# Supabase project settings.
# Required for per-user PR analysis history.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Custom email OTP SMTP settings. Keep these server-side only.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="PRISM Support <your-email@example.com>"

# Session signing secret. Use a long random value in production.
AUTH_SESSION_SECRET=

# Pick one: groq | openai | claude | gemini
AI_PROVIDER=groq

# Default provider.
GROQ_API_KEY=

# Optional providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
