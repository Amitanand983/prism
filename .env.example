# GitHub Personal Access Token.
# Optional for many public PRs, recommended to avoid low unauthenticated rate limits.
GITHUB_TOKEN=

# Pick one: groq | openai | claude | gemini
AI_PROVIDER=groq

# Default provider.
GROQ_API_KEY=

# Optional providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
